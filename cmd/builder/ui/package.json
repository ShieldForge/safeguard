{
  "name": "safeguard-builder-ui",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,json,css,md}": "prettier --write"
  },
  "scripts": {
    "dev": "vite",
    "lint": "npx eslint src && npx prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "compile": "npx prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\" && tsc -p ./",
    "build": "npx prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\" && tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.0.5",
    "vitest": "^4.1.2"
  }
}
